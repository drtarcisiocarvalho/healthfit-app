# ═══════════════════════════════════════════════════════
# HealthFit Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control
# ═══════════════════════════════════════════════════════

# ── App Configuration ──
NODE_ENV=development
PORT=3000
EXPO_PORT=8081

# ── OAuth / Authentication ──
VITE_APP_ID=your_app_id_here
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=your_owner_open_id

# ── JWT / Session Security ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_secure_random_string

# ── Database ──
DATABASE_URL=mysql://user:password@host:3306/healthfit_db

# ── External APIs (Server-side only - NEVER expose to frontend) ──
BUILT_IN_FORGE_API_URL=https://your-forge-api-url.com
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here

# ── CORS Allowed Origins (comma-separated, for production) ──
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Frontend Public Variables (safe to expose - prefixed with EXPO_PUBLIC_) ──
EXPO_PUBLIC_OAUTH_PORTAL_URL=https://your-oauth-portal.com
EXPO_PUBLIC_OAUTH_SERVER_URL=https://your-oauth-server.com
EXPO_PUBLIC_APP_ID=your_app_id_here
EXPO_PUBLIC_OWNER_OPEN_ID=your_owner_id
EXPO_PUBLIC_OWNER_NAME=YourName
EXPO_PUBLIC_API_BASE_URL=https://your-api-server.com

# ── Stripe (publishable key only - safe for frontend) ──
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# Stripe secret key - SERVER ONLY, never in frontend
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
